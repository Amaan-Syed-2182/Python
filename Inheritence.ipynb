   "source": [
    "class a:\n",
    "\n",
    "    def add():\n",
    "        a = 10\n",
    "        b = 20\n",
    "\n",
    "        print(a+b)\n",
    "\n",
    "class b(a):\n",
    "    def subtract():\n",
    "        a = 20\n",
    "        b = 10\n",
    "        print(a-b)\n",
    "\n",
    "obj = b\n",
    "obj.add()\n",
    "obj.subtract()"
   ]
